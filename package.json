{
  "name": "canfly-ai",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check-i18n": "node scripts/check-i18n.js",
    "build": "node scripts/check-i18n.js && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "db:migrate": "wrangler d1 migrations apply canfly-community",
    "db:migrate:local": "wrangler d1 migrations apply canfly-community --local",
    "db:seed:local": "wrangler d1 execute canfly-community --local --file=migrations/0001_initial.sql && wrangler d1 execute canfly-community --local --file=migrations/rollback/seed.sql",
    "db:seed:api": "npx tsx scripts/seed-community.ts",
    "scrape": "npx tsx scripts/scrape-community.ts",
    "scrape:prod": "npx tsx scripts/scrape-community.ts https://canfly.ai",
    "scrape:base": "npx tsx scripts/scrape-base-chain.ts",
    "scrape:base:prod": "npx tsx scripts/scrape-base-chain.ts https://canfly.ai",
    "scrape:discord": "npx tsx scripts/scrape-discord.ts",
    "scrape:discord:prod": "npx tsx scripts/scrape-discord.ts https://canfly.ai",
    "db:rollback:local": "wrangler d1 execute canfly-community --local --file=migrations/rollback/0001_initial_down.sql",
    "db:tables:local": "wrangler d1 execute canfly-community --local --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name\""
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^9.0.1",
    "@privy-io/react-auth": "^3.17.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@runwayml/avatars-react": "^0.7.2",
    "@runwayml/sdk": "^3.15.0",
    "@worldcoin/idkit": "^4.0.10",
    "hls.js": "^1.6.15",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.6",
    "react-markdown": "^10.1.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.13.1",
    "satori": "^0.26.0",
    "viem": "^2.47.5",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
