        },
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Task created with status paid"
          },
          "402": {
            "description": "Payment Required \u2014 MPP challenge or tx_hash needed"
          }
        }
      },
      "get": {
        "summary": "List tasks",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task list"
          }
        }
      }
    }
  }
}