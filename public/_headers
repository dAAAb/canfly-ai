# Cache index.html aggressively short to prevent stale JS references
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Hashed assets can be cached forever (filename changes on rebuild)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
