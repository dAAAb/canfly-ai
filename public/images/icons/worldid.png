nnect\":\"How to connect\",\"built_by\":\"Built by\",\"platform\":\"Platform\",\"type\":\"Type\",\"website\":\"Website\",\"not_available\":\"Content is not available\"},\"app_categories\":{\"entertainment\":\"Entertainment\",\"food_beverages\":\"Food \u0026 Beverages\",\"public_service\":\"Public Service\",\"retail\":\"Retail\",\"tourism\":\"Tourism\",\"transportation\":\"Transportation\",\"wellness\":\"Wellness\",\"university\":\"University\"}},\"careers\":{\"jobs\":{\"all_teams\":\"All Teams\",\"no_jobs_found\":\"No jobs found\",\"remote\":\"Remote\"},\"eeo\":{\"equal_opportunity\":\"Worldcoin is an Equal Opportunity / Affirmative Action employer committed to diversity in the workplace. All qualified applicants will receive consideration for employment without regard to race, color, religion, sex, sexual orientation, age, national origin, disability, protected veteran status, gender identity or any other factor protected by applicable federal, state or local laws. Worldcoin is also committed to working with and providing reasonable accommodations to individuals with disabilities. Please let your recruiter know if you need an accommodation at any point during the interview process.\",\"accommodations\":\"Worldcoin is also committed to working with and providing reasonable accommodations to individuals with disabilities. Please let your recruiter know if you need an accommodation at any point during the interview process.\",\"e_verify_participates\":\"Worldcoin participates in the\"}},\"worldcoin\":{\"metrics\":{\"active_orbs\":\"Active Orbs\",\"countries_with_world_id_users\":\"Countries with World ID users\",\"daily_wallet_transactions\":\"Daily wallet transactions\",\"tokens_distributed\":\"Tokens distributed\",\"total_wallet_transactions\":\"Total wallet transactions\",\"unique_humans\":\"Unique humans\",\"verifications_last_7_days\":\"Verifications in last 7 days\",\"wallet_transactions\":\"Wallet transactions\",\"new_accounts_last_7_days\":\"New accounts in last 7 days\",\"world_app_users\":\"World App users\",\"humans\":\"Humans\",\"transactions\":\"Transactions\",\"transactions_today\":\"Transactions Today\",\"active_wallets\":\"Active Wallets\",\"active_wallets_today\":\"Active Wallets Today\",\"trading_volume_today\":\"Trading Volume Today\",\"trading_volume\":\"Trading Volume\",\"blockchains\":\"Blockchains\",\"credentials\":\"Credentials\",\"optimism\":\"Optimism\",\"other_wallets\":\"Other Wallets\",\"polygon\":\"Polygon\",\"proof_of_personhood_wallets\":\"Proof of Personhood Wallets\",\"world_id_protocol\":\"World ID Protocol\",\"open_sourced\":\"Open sourced\",\"in_progress\":\"In progress\"},\"intervals\":{\"day\":\"Day\",\"week\":\"Week\",\"month\":\"Month\",\"year\":\"Year\",\"all\":\"All\"}},\"open-source\":{\"protocol\":{\"state_bridges\":{\"title\":\"State bridges\",\"description\":\"State bridge between the World ID Ethereum mainnet deployment and World ID supported EVM networks.\"},\"main_protocol\":{\"title\":\"Main Protocol\",\"subtitle\":\"Ethereum mainnet\",\"description\":\"Mainnet is the primary public Ethereum production blockchain, where actual-value transactions occur on the distributed ledger.\"},\"sequencer_indexer\":{\"title\":\"Sequencer \u0026 Indexer\",\"description\":\"Service that inserts verified World IDs on-chain (batched) and fetches inclusion proofs to generate ZKPs for World ID.\"},\"world_id_sdk\":{\"title\":\"World ID SDK\",\"description\":\"Set of tools, libraries, APIs, examples and documentation to easily use the World ID Protocol.\"},\"world_app\":{\"title\":\"World App\",\"description\":\"World App is the first app for the Worldcoin ecosystem. Intentionally designed for simplicity and inclusivity.\"},\"metadata_service\":{\"title\":\"Metadata Service\",\"description\":\"The metadata service within Worldcoin's Developer Portal provides a verified source of information for World ID apps and actions.\"},\"uniqueness_service\":{\"title\":\"Uniqueness Service\",\"description\":\"